{
  "name": "@adeficior/assembler",
  "type": "module",
  "version": "0.0.0-dev",
  "module": "./dist/index.js",
  "exports": {
    ".": "./dist/index.js",
    "./global": "./dist/global.js"
  },
  "types": "./dist/index.d.ts",
  "bin": {
    "assembler": "./dist/cli.js"
  },
  "scripts": {
    "cli": "bun run src/main.ts",
    "build": "tsc --project tsconfig.build.json",
    "check": "tsc --noEmit",
    "lint": "eslint src",
    "format": "prettier --write src",
    "test:ci": "bun run lint"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Adeficior/Assembler.git"
  },
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/Adeficior/Assembler/issues"
  },
  "homepage": "https://github.com/Adeficior/Assembler#readme",
  "files": [
    "dist/"
  ],
  "devDependencies": {
    "typescript": "^6.0.1-rc",
    "@types/bun": "latest",
    "eslint": "^10.5.0",
    "@eslint/js": "^10.0.1",
    "typescript-eslint": "^8.61.0"
  },
  "dependencies": {
    "@adeficior/data-modifier": "^1.0.0-rc.27",
    "arg": "^5.0.2"
  }
}